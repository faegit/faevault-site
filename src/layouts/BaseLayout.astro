---
import { absoluteUrl, SITE_NAME, SITE_NAME_CN, withBaseAsset } from "../config/site";
import { localeMeta, localePath, otherLocale, uiText, type Locale } from "../i18n/config";
import { ClientRouter } from "astro:transitions";
import FluidBackdrop from "../components/FluidBackdrop.astro";

interface Props {
    locale: Locale;
    title: string;
    description: string;
    routePath?: string;
}

const { locale, title, description, routePath = "/" } = Astro.props;
const alternate = otherLocale(locale);
const text = uiText[locale];
const brandName = locale === "zh-cn" ? SITE_NAME_CN : SITE_NAME;
const canonical = absoluteUrl(`/${locale}${routePath === "/" ? "" : routePath}/`);
---

<!doctype html>
<html lang={localeMeta[locale].htmlLang}>
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="generator" content={Astro.generator} />
        <meta name="description" content={description} />
        <meta name="theme-color" content="#f2f6f4" />
        <link rel="icon" href={withBaseAsset("/favicon.ico")} sizes="any" />
        <link rel="canonical" href={canonical} />
        <link rel="alternate" hreflang={localeMeta[locale].htmlLang} href={canonical} />
        <link rel="alternate" hreflang={localeMeta[alternate].htmlLang} href={absoluteUrl(`/${alternate}${routePath === "/" ? "" : routePath}/`)} />
        <title>{title} · {brandName}</title>
        <ClientRouter />
    </head>
    <body data-fluid-root>
        <div class="ambient-layer" transition:persist="ambient-fluid"><FluidBackdrop /></div>
        <a class="skip-link" href="#main">{text.skipToContent}</a>
        <header class="site-header">
            <a class="brand" href={localePath(locale)} aria-label={`${brandName} ${text.nav.home}`}>{brandName}</a>
            <nav aria-label="Primary">
                <a href={localePath(locale)}>{text.nav.home}</a>
                <a href={localePath(locale, "guides")}>{text.nav.guides}</a>
                <a href={localePath(locale, "download")}>{text.nav.download}</a>
                <a href={localePath(locale, "journey")}>{text.nav.journey}</a>
                <a href={localePath(locale, "security")}>{text.nav.security}</a>
                <a class="support-link" href={localePath(locale, "support")}>{text.nav.support}</a>
            </nav>
            <a class="language-switch" href={localePath(alternate, routePath)} hreflang={localeMeta[alternate].htmlLang}>{text.switchLanguage}</a>
        </header>
        <main id="main" transition:animate="fade"><slot /></main>
        <footer class="site-footer">
            <a href="https://github.com/faegit/faevault-site" target="_blank" rel="noopener noreferrer">
                <img src="https://img.shields.io/github/stars/faegit/faevault-site?style=social" alt="GitHub Stars" />
                <img src="https://img.shields.io/github/forks/faegit/faevault-site?style=social" alt="GitHub Forks" />
            </a>
        </footer>
    </body>
</html>

<style is:global>
    :root {
        color-scheme: light;
        font-family:
            Inter,
            ui-sans-serif,
            system-ui,
            -apple-system,
            BlinkMacSystemFont,
            "Segoe UI",
            sans-serif;
        background: #f2f6f4;
        color: #172b35;
    }
    * {
        box-sizing: border-box;
    }
    html {
        scroll-behavior: smooth;
        scrollbar-gutter: stable;
    }
    body {
        margin: 0;
        min-width: 320px;
        overflow-x: hidden;
    }
    a {
        color: inherit;
        text-decoration: none;
    }
    .skip-link {
        position: fixed;
        top: 0.75rem;
        left: 0.75rem;
        z-index: 100;
        padding: 0.65rem 1rem;
        border-radius: 999px;
        background: #172030;
        color: #fff;
        transform: translateY(-160%);
    }
    .skip-link:focus {
        transform: translateY(0);
    }
    .site-header {
        position: fixed;
        top: 1rem;
        left: 50%;
        z-index: 30;
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        gap: 2rem;
        width: min(1180px, calc(100% - 2rem));
        padding: 0.75rem 1rem;
        border: 1px solid rgba(255, 255, 255, 0.72);
        border-radius: 999px;
        background: rgba(250, 253, 252, 0.68);
        box-shadow: 0 14px 44px rgba(41, 61, 91, 0.09);
        backdrop-filter: blur(18px);
        transform: translateX(-50%);
    }
    .brand {
        font-weight: 760;
        letter-spacing: -0.04em;
    }
    nav {
        display: flex;
        align-items: center;
        gap: 1.25rem;
        color: #526074;
        font-size: 0.92rem;
    }
    nav a,
    .language-switch {
        transition:
            color 0.2s ease,
            transform 0.2s ease;
    }
    nav a:hover,
    .language-switch:hover {
        color: #3579f6;
        transform: translateY(-1px);
    }
    .support-link {
        color: #2869df;
        font-weight: 650;
    }
    .language-switch {
        justify-self: end;
        font-size: 0.9rem;
        color: #526074;
    }
    main {
        min-height: 80vh;
    }
    .site-footer {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 1rem;
        padding: 2rem 1rem 3rem;
    }
    .site-footer a {
        display: flex;
        gap: 0.75rem;
        align-items: center;
        opacity: 0.55;
        transition: opacity 0.25s ease;
    }
    .site-footer a:hover {
        opacity: 0.85;
    }
    .site-footer img {
        height: 20px;
    }
    .ambient-layer {
        position: fixed;
        inset: 0;
        z-index: -2;
        pointer-events: none;
    }
    ::view-transition-old(root) {
        animation: 0.22s ease both crossfade-out;
    }
    ::view-transition-new(root) {
        animation: 0.24s ease 0.06s both crossfade-in;
        mix-blend-mode: normal;
    }
    @keyframes crossfade-out {
        to {
            opacity: 0;
        }
    }
    @keyframes crossfade-in {
        from {
            opacity: 0;
        }
    }
    @media (max-width: 760px) {
        .site-header {
            grid-template-columns: 1fr auto;
        }
        nav {
            display: none;
        }
        .site-header {
            width: calc(100% - 1.2rem);
            left: 50%;
            transform: translateX(-50%);
            padding: 0.5rem 0.8rem;
            top: 0.6rem;
        }
    }
    @media (prefers-reduced-motion: reduce) {
        html {
            scroll-behavior: auto;
        }
        *,
        *::before,
        *::after {
            animation-duration: 0.01ms !important;
            animation-iteration-count: 1 !important;
            transition-duration: 0.01ms !important;
        }
    }
</style>

