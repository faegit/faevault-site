---
import { absoluteUrl, SITE_NAME, withBaseAsset } from '../config/site';
import { localeMeta, localePath, otherLocale, uiText, type Locale } from '../i18n/config';
import { ClientRouter } from 'astro:transitions';
import FluidBackdrop from '../components/FluidBackdrop.astro';

interface Props {
  locale: Locale;
  title: string;
  description: string;
  routePath?: string;
}

const { locale, title, description, routePath = '/' } = Astro.props;
const alternate = otherLocale(locale);
const text = uiText[locale];
const canonical = absoluteUrl(`/${locale}${routePath === '/' ? '' : routePath}/`);
---

<!doctype html>
<html lang={localeMeta[locale].htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f2f6f4" />
    <link rel="icon" href={withBaseAsset('/favicon.ico')} sizes="any" />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang={localeMeta[locale].htmlLang} href={canonical} />
    <link rel="alternate" hreflang={localeMeta[alternate].htmlLang} href={absoluteUrl(`/${alternate}${routePath === '/' ? '' : routePath}/`)} />
    <title>{title} · {SITE_NAME}</title>
    <ClientRouter />
  </head>
  <body data-fluid-root>
    <div class="ambient-layer" transition:persist="ambient-fluid"><FluidBackdrop /></div>
    <a class="skip-link" href="#main">{text.skipToContent}</a>
    <header class="site-header">
      <a class="brand" href={localePath(locale)} aria-label={`${SITE_NAME} ${text.nav.home}`}>{SITE_NAME}</a>
      <nav aria-label="Primary">
        <a href={localePath(locale)}>{text.nav.home}</a>
        <a href={localePath(locale, 'guides')}>{text.nav.guides}</a>
        <a href={localePath(locale, 'journey')}>{text.nav.journey}</a>
        <a href={localePath(locale, 'download')}>{text.nav.download}</a>
        <a class="support-link" href={localePath(locale, 'support')}>{text.nav.support}</a>
      </nav>
      <a class="language-switch" href={localePath(alternate, routePath)} hreflang={localeMeta[alternate].htmlLang}>{text.switchLanguage}</a>
    </header>
    <main id="main" transition:animate="fade"><slot /></main>
  </body>
</html>

<style is:global>
  :root { color-scheme: light; font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; background: #f2f6f4; color: #172b35; }
  * { box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body { margin: 0; min-width: 320px; overflow-x: hidden; }
  a { color: inherit; text-decoration: none; }
  .skip-link { position: fixed; top: .75rem; left: .75rem; z-index: 100; padding: .65rem 1rem; border-radius: 999px; background: #172030; color: #fff; transform: translateY(-160%); }
  .skip-link:focus { transform: translateY(0); }
  .site-header { position: fixed; top: 1rem; left: 50%; z-index: 30; display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; gap: 2rem; width: min(1180px, calc(100% - 2rem)); padding: .75rem 1rem; border: 1px solid rgba(255,255,255,.72); border-radius: 999px; background: rgba(250,253,252,.68); box-shadow: 0 14px 44px rgba(41,61,91,.09); backdrop-filter: blur(18px); transform: translateX(-50%); }
  .brand { font-weight: 760; letter-spacing: -.04em; }
  nav { display: flex; align-items: center; gap: 1.25rem; color: #526074; font-size: .92rem; }
  nav a, .language-switch { transition: color .2s ease, transform .2s ease; }
  nav a:hover, .language-switch:hover { color: #3579f6; transform: translateY(-1px); }
  .support-link { color: #2869df; font-weight: 650; }
  .language-switch { justify-self: end; font-size: .9rem; color: #526074; }
  main { min-height: 80vh; }
  .ambient-layer { position: fixed; inset: 0; z-index: -2; pointer-events: none; }
  ::view-transition-old(root) { animation: .36s cubic-bezier(.45,0,.55,1) both page-out; }
  ::view-transition-new(root) { animation: .58s cubic-bezier(.18,.78,.18,1) both page-in; }
  @keyframes page-out { to { opacity: 0; filter: blur(10px); transform: scale(.985); clip-path: inset(3% 2% 3% 2% round 2rem); } }
  @keyframes page-in { from { opacity: 0; filter: blur(14px); transform: scale(1.018); clip-path: inset(8% 4% 8% 4% round 3rem); } }
  @media (max-width: 760px) { .site-header { grid-template-columns: 1fr auto; } nav { display: none; } }
  @media (prefers-reduced-motion: reduce) { html { scroll-behavior: auto; } *, *::before, *::after { animation-duration: .01ms !important; animation-iteration-count: 1 !important; transition-duration: .01ms !important; } }
</style>

<script>
  (function() {
    if (matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    const selectors = 'main p, main blockquote, main .intro-line span, main .support-story span';
    let observer: IntersectionObserver | null;
    function init() {
      const elements = document.querySelectorAll(selectors);
      if (!elements.length) return;
      observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (!entry.isIntersecting) return;
          const el = entry.target as HTMLElement;
          if (el.dataset.tw) return;
          el.dataset.tw = '1';
          observer!.unobserve(el);
          const text = el.textContent;
          if (!text || text.trim().length < 2) return;
          el.textContent = '';
          let i = 0;
          const base = 28;
          (function tick() {
            if (i < text.length) {
              el.textContent = text.slice(0, i + 1);
              const ch = text[i];
              i++;
              const extra = /[。！？.!?]/.test(ch) ? base * 5
                         : /[，、；,;]/.test(ch) ? base * 2.5
                         : 0;
              setTimeout(tick, base + extra + (Math.random() - .5) * 8);
            }
          })();
        });
      }, { threshold: .08, rootMargin: '0px 0px -20px 0px' });
      elements.forEach(el => observer!.observe(el));
    }
    document.addEventListener('astro:page-load', init);
    init();
  })();
</script>
