---
import type { Locale } from '../i18n/config';
import { localePath } from '../i18n/config';
import DeviceSync from './DeviceSync.astro';

interface Props { locale: Locale; }
const { locale } = Astro.props;
const copy = locale === 'zh-cn' ? {
  eyebrow: '本地优先 · Android + Windows',
  title: '你的密码，\n应该真正属于你。',
  intro: 'FAEVault 把密码、通行密钥与重要资料留在你掌控的保险库中。它认真对待隐私，也认真对待每一次日常使用。',
  support: '直接支持开发',
  storyLink: '阅读开发故事',
  syncLabel: '桌面端与手机端之间的加密数据同步',
  storyKicker: '为什么继续做下去',
  storyTitle: '工具可以很冷静，\n但它保护的是人的生活。',
  storyBody: '一串密码背后，可能是一段工作、一份回忆，或一个不想失去的账号。FAEVault 的故事不会用虚构的苦难催促赞助，而会如实记录那些反复打磨、推倒重来，以及终于让某件事变得更可靠的时刻。',
  quote: '如果它恰好替你省下一次焦虑，那份价值就已经发生了。',
  journeyKicker: '持续发生的开发历程',
  journeyTitle: '不是版本陈列，而是一条仍在生长的路。',
  journeyBody: '这里会连接 Android 与 Windows 两端的关键节点、设计取舍和真实问题。沿着时间向下阅读，而不是翻过一张张像演示文稿的卡片。',
  journeyLink: '进入完整历程',
  guideKicker: '需要时，答案应该很近',
  guideTitle: '从第一次打开，到双端安心使用。',
  guideBody: '教程将按真实操作组织：创建保险库、导入资料、自动填充、通行密钥、同步与备份。每种语言独立呈现，步骤不会混排。',
  guides: '查看使用指南',
  download: '下载最新版本',
  supportKicker: '支持 FAEVault',
  supportTitle: '想直接支持？\n付款码就在下一页最前面。',
  supportBody: '不需要先读完整故事，也不会被长篇内容挡住。你可以直接看到支付宝与微信付款码；如果愿意停留，再继续读开发背后的故事。',
  supportButton: '打开支持页面',
} : {
  eyebrow: 'Local-first · Android + Windows',
  title: 'Your passwords\nshould truly be yours.',
  intro: 'FAEVault keeps passwords, passkeys, and important details inside a vault you control. It takes privacy seriously—and everyday usability just as seriously.',
  support: 'Support development',
  storyLink: 'Read the development story',
  syncLabel: 'Encrypted data moving between desktop and phone',
  storyKicker: 'Why keep building',
  storyTitle: 'Tools can be quiet.\nWhat they protect is human.',
  storyBody: 'Behind a password may be someone\'s work, a memory, or an account they cannot afford to lose. FAEVault will not invent hardship to pressure people into donating. Its story will honestly document the rebuilding, the difficult choices, and the moments when something finally became more dependable.',
  quote: 'If it saves you one moment of anxiety, its value has already become real.',
  journeyKicker: 'An ongoing development journey',
  journeyTitle: 'Not a version showcase, but a path that is still growing.',
  journeyBody: 'This timeline will connect important moments, design tradeoffs, and real problems across Android and Windows. It reads as an unfolding story, not a stack of presentation slides.',
  journeyLink: 'Explore the full journey',
  guideKicker: 'Answers should be close when needed',
  guideTitle: 'From the first launch to confident use across devices.',
  guideBody: 'Guides will follow real workflows: creating a vault, importing data, autofill, passkeys, sync, and backup. Each language stands on its own, with no mixed-language instructions.',
  guides: 'Browse the guides',
  download: 'Download the latest version',
  supportKicker: 'Support FAEVault',
  supportTitle: 'Want to help directly?\nThe payment codes come first.',
  supportBody: 'You will not have to read the entire story first. Alipay and WeChat codes appear immediately; if you want to stay, the story continues below them.',
  supportButton: 'Open the support page',
};

const sections = [
  { id: 'opening', labelZH: '首页', labelEN: 'Home' },
  { id: 'why', labelZH: '故事', labelEN: 'Story' },
  { id: 'journey', labelZH: '历程', labelEN: 'Journey' },
  { id: 'guides', labelZH: '指南', labelEN: 'Guides' },
  { id: 'support', labelZH: '支持', labelEN: 'Support' },
];
const navLabels = locale === 'zh-cn'
  ? sections.map(s => s.labelZH)
  : sections.map(s => s.labelEN);
---

<div class="home" data-snap-container>
  <nav class="snap-nav" aria-label="Section navigation">
    {sections.map((s, i) => (
      <a href={`#${s.id}`} data-snap-dot={i} aria-label={navLabels[i]}><span>{navLabels[i]}</span></a>
    ))}
  </nav>

  <section class="snap-section hero" id="opening">
    <div class="hero-inner">
      <div class="hero-copy">
        <p class="eyebrow">{copy.eyebrow}</p>
        <h1>{copy.title.split('\n').map((line) => <>{line}<br /></>)}</h1>
        <p class="intro">{copy.intro}</p>
        <div class="actions">
          <a class="primary" href={localePath(locale, 'support')}>{copy.support}</a>
          <a class="text-link" href={localePath(locale, 'journey')}>{copy.storyLink}<span>→</span></a>
        </div>
      </div>
      <div class="device-wrap"><DeviceSync label={copy.syncLabel} /></div>
    </div>
    <div class="scroll-hint" aria-hidden="true"><i></i><i></i><i></i></div>
  </section>

  <section class="snap-section split" id="why">
    <div class="split-inner">
      <div class="split-copy"><p class="eyebrow">{copy.storyKicker}</p><h2>{copy.storyTitle.split('\n').map((line) => <>{line}<br /></>)}</h2></div>
      <div class="prose"><p>{copy.storyBody}</p><blockquote>{copy.quote}</blockquote></div>
    </div>
  </section>

  <section class="snap-section journey" id="journey">
    <div class="journey-line" aria-hidden="true"><i></i><i></i><i></i></div>
    <div class="journey-inner">
      <div class="journey-copy"><p class="eyebrow">{copy.journeyKicker}</p><h2>{copy.journeyTitle}</h2><p>{copy.journeyBody}</p><a class="text-link" href={localePath(locale, 'journey')}>{copy.journeyLink}<span>→</span></a></div>
      <div class="milestones" aria-hidden="true"><span>01</span><span>Android</span><span>Windows</span><span>Now</span></div>
    </div>
  </section>

  <section class="snap-section guide-section" id="guides">
    <div class="guide-inner">
      <p class="eyebrow">{copy.guideKicker}</p><h2>{copy.guideTitle}</h2><p>{copy.guideBody}</p>
      <div class="actions"><a class="primary muted" href={localePath(locale, 'guides')}>{copy.guides}</a><a class="text-link" href={localePath(locale, 'download')}>{copy.download}<span>↓</span></a></div>
    </div>
  </section>

  <section class="snap-section support-section" id="support">
    <div class="support-inner">
      <p class="eyebrow">{copy.supportKicker}</p><h2>{copy.supportTitle.split('\n').map((line) => <>{line}<br /></>)}</h2><p>{copy.supportBody}</p>
      <a class="support-button" href={localePath(locale, 'support')}>{copy.supportButton}<span>→</span></a>
    </div>
  </section>
</div>

<style>
  :root { --snap-duration: .72s; }
  html:has(.home) { overflow: hidden; height: 100%; }
  .home { height: 100vh; overflow-y: scroll; scroll-snap-type: y mandatory; scroll-behavior: smooth; }
  .snap-section { min-height: 100vh; scroll-snap-align: start; display: flex; flex-direction: column; justify-content: center; position: relative; }
  .snap-section > * { width: min(1180px, calc(100% - 6rem)); margin: 0 auto; }

  .hero-inner { display: grid; grid-template-columns: minmax(340px, 580px) minmax(420px, 1fr); gap: 3vw; align-items: center; }
  .hero-copy { padding: 0 .5rem; }
  .eyebrow { margin: 0 0 1rem; color: #287795; font-size: .72rem; font-weight: 820; letter-spacing: .16em; text-transform: uppercase; }
  h1, h2 { font-family: Georgia, 'Times New Roman', serif; font-weight: 500; letter-spacing: -.052em; }
  h1 { margin: 0; font-size: clamp(3rem, 5.5vw, 5.2rem); line-height: 1.01; }
  h2 { margin: 0; font-size: clamp(2.2rem, 4.5vw, 4.2rem); line-height: 1.06; }
  .intro { max-width: 520px; margin: 1.4rem 0 0; color: #4f6974; font: 1rem/1.8 Georgia, serif; }
  .actions { display: flex; flex-wrap: wrap; gap: 1.3rem; align-items: center; margin-top: 1.8rem; }
  .primary, .support-button { padding: .85rem 1.2rem; border-radius: 999px; background: #173f50; color: #fff; font-size: .85rem; font-weight: 750; box-shadow: 0 13px 30px rgba(23,63,80,.17); transition: transform .25s ease, box-shadow .25s ease, background .25s ease; }
  .primary:hover, .support-button:hover { transform: translateY(-3px); background: #20596f; box-shadow: 0 18px 36px rgba(23,63,80,.24); }
  .primary.muted { background: #315f72; }
  .text-link { display: inline-flex; gap: .6rem; align-items: center; padding-bottom: .2rem; border-bottom: 1px solid rgba(46,110,134,.45); color: #245e75; font-size: .83rem; font-weight: 760; transition: gap .25s ease, color .25s ease; }
  .text-link:hover { gap: .9rem; color: #1980a4; }
  .device-wrap { justify-self: end; transform: scale(.88); transform-origin: right center; }
  .device-wrap :global(.device-stage) { width: 520px; height: 400px; }

  .scroll-hint { position: absolute; bottom: 2.5rem; left: 50%; transform: translateX(-50%); display: flex; flex-direction: column; align-items: center; gap: 4px; opacity: .4; }
  .scroll-hint i { width: 2px; height: 14px; border-radius: 99px; background: #3d7d93; animation: scroll-bounce 2.2s ease-in-out infinite; }
  .scroll-hint i:nth-child(2) { animation-delay: .25s; } .scroll-hint i:nth-child(3) { animation-delay: .5s; }
  @keyframes scroll-bounce { 0%, 60%, 100% { transform: translateY(0); opacity: .3; } 30% { transform: translateY(6px); opacity: .9; } }

  .split-inner { display: grid; grid-template-columns: 1.05fr .8fr; gap: 7vw; align-items: center; }
  .prose > p { color: #5a727c; font: 1rem/1.9 Georgia, serif; }
  blockquote { margin: 2.5rem 0 0; padding: 0 0 0 1.4rem; border-left: 2px solid rgba(43,124,154,.5); color: #254c5d; font: italic 1.35rem/1.5 Georgia, serif; }

  .journey-inner { display: grid; grid-template-columns: 1fr .4fr; gap: 7vw; align-items: center; }
  .journey-copy { max-width: 660px; }
  .journey-copy > p, .guide-section > p, .support-section > p { color: #5a727c; font: 1rem/1.9 Georgia, serif; }
  .journey-copy > p { max-width: 580px; margin: 1.4rem 0; }
  .journey-line { position: absolute; right: 23%; top: 14%; bottom: 14%; width: 70px; border-left: 1px dashed rgba(42,113,140,.27); transform: rotate(4deg); }
  .journey-line i { position: absolute; left: -5px; width: 10px; height: 10px; border: 2px solid #3c8eaa; border-radius: 50%; background: #eef7f5; box-shadow: 0 0 0 7px rgba(60,142,170,.08); }
  .journey-line i:nth-child(1) { top: 7%; } .journey-line i:nth-child(2) { top: 46%; left: 3px; } .journey-line i:nth-child(3) { top: 87%; left: -9px; }
  .milestones { display: flex; flex-direction: column; gap: 1.2rem; align-items: flex-end; color: #65808a; font: .74rem/1 ui-monospace, monospace; letter-spacing: .12em; }

  .guide-section { justify-content: center; }
  .guide-inner { max-width: 720px; margin-left: max(6vw, calc((100vw - 1180px)/2)) !important; }
  .guide-inner > p { max-width: 600px; margin: 1.2rem 0 0; }

  .support-section { justify-content: center; }
  .support-inner { width: min(900px, calc(100% - 3rem)) !important; margin: 0 auto !important; padding: clamp(3.5rem, 7vw, 6rem); border: 1px solid rgba(255,255,255,.7); border-radius: 2.5rem; background: linear-gradient(135deg, rgba(229,248,247,.82), rgba(229,237,251,.68)); box-shadow: 0 28px 90px rgba(42,83,99,.12); backdrop-filter: blur(22px); }
  .support-inner h2 { max-width: 700px; }
  .support-inner > p { max-width: 580px; margin: 1.4rem 0 2rem; }
  .support-button { display: inline-flex; align-items: center; gap: .7rem; }
  .support-button:hover { gap: 1rem; }

  .snap-nav { position: fixed; right: 1.5rem; top: 50%; z-index: 20; transform: translateY(-50%); display: flex; flex-direction: column; gap: .65rem; }
  .snap-nav a { position: relative; display: flex; align-items: center; justify-content: center; width: 28px; height: 28px; text-decoration: none; }
  .snap-nav a::before { content: ''; width: 7px; height: 7px; border-radius: 50%; background: rgba(60,112,130,.3); transition: transform .4s cubic-bezier(.2,.75,.2,1), background .4s ease, box-shadow .4s ease; }
  .snap-nav a:hover::before { transform: scale(1.5); background: rgba(60,112,130,.55); }
  .snap-nav a.active::before { transform: scale(1.6); background: #287795; box-shadow: 0 0 0 5px rgba(40,119,149,.15); }
  .snap-nav a span { position: absolute; right: calc(100% + 12px); top: 50%; transform: translateY(-50%); padding: 2px 8px; border-radius: 4px; background: rgba(40,50,60,.75); color: #fff; font-size: .68rem; white-space: nowrap; opacity: 0; pointer-events: none; transition: opacity .2s ease, transform .2s ease; }
  .snap-nav a:hover span, .snap-nav a.active span { opacity: 1; }

  @media (max-width: 1000px) {
    .hero-inner { grid-template-columns: minmax(0,1fr); }
    .device-wrap { justify-self: center; transform: scale(.78); transform-origin: center; }
    .hero-inner > * { min-width: 0; }
    .split-inner { grid-template-columns: 1fr; gap: 2.5rem; }
    .journey-inner { grid-template-columns: 1fr; gap: 2rem; }
    .journey-line { right: 2rem; }
    .milestones { flex-direction: row; justify-content: flex-end; gap: 2rem; }
    .guide-inner { margin-left: 0 !important; }
  }
  @media (max-width: 760px) {
    .hero-inner { padding-top: 2rem; }
    .device-wrap { transform: scale(.6); transform-origin: center; margin-bottom: -2rem; }
    .scroll-hint { display: none; }
    .snap-nav { right: .75rem; }
    .journey-line { display: none; }
    .milestones { display: none; }
    .support-inner { border-radius: 1.7rem; padding: 3rem 1.5rem; }
    .snap-section > * { width: calc(100% - 2.5rem); }
  }
</style>

<script>
  (function() {
    const home = document.querySelector('.home') as HTMLElement | null;
    if (!home) return;

    const sections = home.querySelectorAll('.snap-section');
    const dots = home.querySelectorAll('[data-snap-dot]');
    const scrollHint = home.querySelector('.scroll-hint') as HTMLElement | null;

    let activeIndex = -1;
    let ticking = false;

    function updateNav(index: number) {
      dots.forEach((dot, i) => dot.classList.toggle('active', i === index));
      if (scrollHint) scrollHint.style.opacity = index === 0 ? '.4' : '0';
    }

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting && entry.intersectionRatio >= .35) {
          const idx = [...sections].indexOf(entry.target);
          if (idx !== activeIndex) {
            activeIndex = idx;
            if (!ticking) {
              requestAnimationFrame(() => { updateNav(activeIndex); ticking = false; });
              ticking = true;
            }
          }
        }
      });
    }, { threshold: [.35, .5, .65] });

    sections.forEach(s => observer.observe(s));

    dots.forEach(dot => {
      dot.addEventListener('click', (e) => {
        e.preventDefault();
        const href = dot.getAttribute('href');
        if (!href) return;
        const target = document.getElementById(href.slice(1));
        if (target) target.scrollIntoView({ behavior: 'smooth' });
      });
    });

    document.addEventListener('astro:before-swap', () => { observer.disconnect(); });
  })();
</script>
