<script>
(function() {
    const stack = document.querySelector<HTMLElement>(".workflow-stack");
    if (!stack) return;
    const el = stack as HTMLElement;
    const CARDS = Array.from(el.children) as HTMLElement[];
    const COUNT = CARDS.length;
    if (COUNT < 2) return;

    function equalizeHeights() {
        let maxH = 0;
        CARDS.forEach(c => { c.style.height = "auto"; maxH = Math.max(maxH, c.offsetHeight); });
        if (maxH > 0) CARDS.forEach(c => { c.style.height = `${maxH}px`; });
        return maxH;
    }

    function applyOffsets(activeIndex: number) {
        CARDS.forEach((card, i) => {
            const offset = (i - activeIndex + COUNT) % COUNT;
            const y = offset * 18;
            const scale = 1 - offset * 0.035;
            card.style.transition = "transform 420ms ease, opacity 420ms ease";
            card.style.transform = `translateY(${y}px) scale(${scale})`;
            card.style.zIndex = `${COUNT - offset}`;
            card.style.opacity = String(1 - offset * 0.06);
            card.classList.toggle("active", offset === 0);
        });
    }

    let current = 0;
    let running = false;
    equalizeHeights();
    applyOffsets(0);
    document.addEventListener("astro:page-load", () => { equalizeHeights(); applyOffsets(current); });
    window.addEventListener("resize", () => { equalizeHeights(); applyOffsets(current); });

    // Click to bring card to front
    CARDS.forEach((card, i) => {
        card.addEventListener("click", function onClick() {
            if (running || i === current) return;
            running = true;
            const oldCard = CARDS[current];
            oldCard.classList.add("fade-up");
            setTimeout(() => {
                current = i;
                oldCard.classList.remove("fade-up");
                applyOffsets(current);
                running = false;
            }, 440);
        });
    });

    // Auto-rotate
    const DELAY = 4500;
    let timer = setInterval(() => {
        if (running) return;
        running = true;
        const oldCard = CARDS[current];
        oldCard.classList.add("fade-up");
        setTimeout(() => {
            current = (current + 1) % COUNT;
            oldCard.classList.remove("fade-up");
            applyOffsets(current);
            running = false;
        }, 440);
    }, DELAY);

    // Pause on hover
    el.addEventListener("mouseenter", () => { clearInterval(timer); });
    el.addEventListener("mouseleave", () => {
        timer = setInterval(() => {
            if (running) return;
            running = true;
            const oldCard = CARDS[current];
            oldCard.classList.add("fade-up");
            setTimeout(() => {
                current = (current + 1) % COUNT;
                oldCard.classList.remove("fade-up");
                applyOffsets(current);
                running = false;
            }, 440);
        }, DELAY);
    });
})();
</script>


