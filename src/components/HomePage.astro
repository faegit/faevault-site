---
import type { Locale } from "../i18n/config";
import { localePath } from "../i18n/config";
import DeviceSync from "./DeviceSync.astro";

interface Props {
    locale: Locale;
}
const { locale } = Astro.props;
const copy =
    locale === "zh-cn"
        ? {
              eyebrow: "本地优先 · Android + Windows",
              title: "你的密码和数据，\n完全由你掌控。",
              intro: "保险库把密码、通行密钥与重要资料放进一个本地加密库，并为 Windows Hello、浏览器自动填充与多设备同步打基础。",
              support: "直接赞助支持开发",
              storyLink: "了解产品故事",
              syncLabel: "桌面端与手机端之间的加密数据同步",
              storyKicker: "为什么值得信赖",
              storyTitle: "简洁的体验，\n来自对隐私的认真。",
              storyBody: "基于本地加密库文件，保险库在 Windows 与 Android 之间保持一致体验，兼顾离线安全与智能填充。",
              quote: "一个更安心的日常习惯，往往从一次更清晰的选择开始。",
              journeyKicker: "持续推进的产品理念",
              journeyTitle: "不是一次性功能展示，\n而是一段持续完善的路径。",
              journeyBody: "从 Android 到 Windows，保险库会不断把产品体验打磨得更顺手、更可靠。",
              journeyLink: "查看开发历程",
              guideKicker: "功能展示",
              guideTitle: "保险库具备的\n实用功能。",
              guideBody: "从本地加密存储到系统自动填充，保险库为 Android 和 Windows 提供完整的密码管理能力。",
              guides: "查看使用指南",
              download: "下载最新版本",
              supportKicker: "赞助支持项目",
              supportTitle: "如果你愿意赞助支持，\n付款码就在这里。",
              supportButton: "打开赞助页面",
          }
        : {
              eyebrow: "Local-first · Android + Windows",
              title: "Your passwords\nshould truly be yours.",
              intro: "FAEVault keeps passwords, passkeys, and important details inside a vault you can truly control.",
              support: "Support development",
              storyLink: "Learn the story",
              syncLabel: "Encrypted data moving between desktop and phone",
              storyKicker: "Why it feels trustworthy",
              storyTitle: "A calm experience,\nbuilt around privacy.",
              storyBody: "Built around a local encrypted vault file, FAEVault brings browser autofill, Windows Hello unlock, and private sync across devices.",
              quote: "A calmer daily routine often begins with one clearer decision.",
              journeyKicker: "A product in progress",
              journeyTitle: "Not a one-off feature showcase,\nbut a path that keeps improving.",
              journeyBody: "From Android to Windows, FAEVault keeps refining the experience into something more dependable.",
              journeyLink: "See the development journey",
              guideKicker: "Feature showcase",
              guideTitle: "Practical features\nfor everyday use.",
              guideBody: "From local encrypted storage to system-level autofill, FAEVault delivers complete password management for Android and Windows.",
              guides: "Browse the guides",
              download: "Download the latest version",
              supportKicker: "Support the project",
              supportTitle: "If you want to help,\nthe payment options are here.",
              supportButton: "Open the support page",
          };

const features =
    locale === "zh-cn"
        ? [
              { title: "本地加密保险库", body: "scrypt + AES-256-GCM 加密，密码与通行密钥离线存储在本地文件中，数据完全由你掌控。", accent: "vault" },
              { title: "系统自动填充", body: "Android Autofill 框架集成，一键填入登录凭证与一次性验证码，支持关联应用和网页。", accent: "flow" },
              { title: "通行密钥", body: "Android 14+ Passkey Credential Provider，支持创建和验证通行密钥，实现无密码快速认证。", accent: "passkey" },
              { title: "OCR 智能识别", body: "摄像头扫描或相册导入银行卡、身份证，自动 OCR 提取卡号、有效期、姓名等信息填入对应字段。", accent: "ocr" },
              { title: "安全防护", body: "FLAG_SECURE 防截屏录屏，剪贴板 60 秒自动清空，暴力破解指数冷却，敏感信息二次验证。", accent: "security" },
              { title: "加密同步", body: "WebDAV 连接 NAS 或 Nextcloud、局域网直连同步、加密备份导出，多设备间安全保持数据一致。", accent: "sync" },
          ]
        : [
              { title: "Encrypted Vault", body: "scrypt + AES-256-GCM encryption. Passwords and passkeys stay in a local file, fully under your control.", accent: "vault" },
              { title: "System Autofill", body: "Integrated with Android Autofill framework. Fill credentials and OTPs with one tap in apps and websites.", accent: "flow" },
              { title: "Passkeys", body: "Android 14+ Passkey Credential Provider. Create and verify passkeys for passwordless, fast authentication.", accent: "passkey" },
              { title: "OCR Scanning", body: "Scan credit cards and IDs via camera or gallery. Auto-extract card numbers, expiry dates, and personal details.", accent: "ocr" },
              { title: "Security Guard", body: "Anti-screenshot with FLAG_SECURE, 60-second auto-clear clipboard, exponential brute-force lockout, sensitive data re-verification.", accent: "security" },
              { title: "Encrypted Sync", body: "WebDAV for NAS/Nextcloud, LAN direct sync, encrypted backup export. Keep data consistent across devices.", accent: "sync" },
          ];
---

<div class="home">
    <section class="section hero" id="opening">
        <div class="hero-inner">
            <div class="hero-copy">
                <p class="eyebrow">{copy.eyebrow}</p>
                <h1>
                    {
                        copy.title.split("\n").map((line) => (
                            <>
                                {line}
                                <br />
                            </>
                        ))
                    }
                </h1>
                <p class="intro">{copy.intro}</p>
                <div class="actions">
                    <a class="primary" href={localePath(locale, "download")}>{copy.download}<span aria-hidden="true">→</span></a>
                    <a class="secondary" href={localePath(locale, "guides")}>{copy.guides}<span aria-hidden="true">→</span></a>
                    <a class="text-link" href={localePath(locale, "journey")}>{copy.storyLink}<span aria-hidden="true">→</span></a>
                </div>
            </div>
            <div class="device-wrap"><DeviceSync label={copy.syncLabel} /></div>
        </div>
    </section>

    <section class="section guide-section" id="guides">
        <div class="guide-inner">
            <div class="guide-head section-copy">
                <p class="eyebrow">{copy.guideKicker}</p>
                <h2>{copy.guideTitle}</h2>
                <p>{copy.guideBody}</p>
            </div>
            <div class="workflow-side">
                <div class="workflow-stack">
                    {
                        features.map((item) => (
                            <article class="workflow-card" data-feature>
                                <span class={`workflow-dot ${item.accent}`} />
                                <strong>{item.title}</strong>
                                <p>{item.body}</p>
                            </article>
                        ))
                    }
                </div>
            </div>
        </div>
    </section>

    <section class="section split" id="why">
        <div class="split-inner">
            <div class="split-copy section-copy">
                <p class="eyebrow">{copy.storyKicker}</p>
                <h2>{copy.storyTitle}</h2>
                <blockquote class="slide-quote">{copy.quote}</blockquote>
            </div>
            <div class="showcase-wrap" aria-label={locale === "zh-cn" ? "保险库 产品展示" : "FAEVault product showcase"}>
                <div class="showcase-shell">
                    <div class="showcase-glow"></div>
                    <div class="showcase-card">
                        <div class="showcase-topbar">
                            <div class="topbar-dots"><span></span><span></span><span></span></div>
                            <div class="topbar-label">{locale === "zh-cn" ? "本地优先 · 私有同步" : "Local-first · Private sync"}</div>
                        </div>
                        <div class="showcase-grid">
                            <div class="showcase-panel panel-left">
                                <div class="feature-pill">{locale === "zh-cn" ? "保险库" : "Vault"}</div>
                                <div class="panel-stack">
                                    <div class="panel-row active">
                                        <span class="panel-icon"></span>
                                        <span class="panel-text">
                                            <strong>{locale === "zh-cn" ? "通行密钥" : "Passkeys"}</strong>
                                            <em>{locale === "zh-cn" ? "离线可用" : "Offline ready"}</em>
                                        </span>
                                    </div>
                                    <div class="panel-row">
                                        <span class="panel-icon muted"></span>
                                        <span class="panel-text">
                                            <strong>{locale === "zh-cn" ? "密码列表" : "Passwords"}</strong>
                                            <em>{locale === "zh-cn" ? "一键整理" : "Cleanly grouped"}</em>
                                        </span>
                                    </div>
                                    <div class="panel-row">
                                        <span class="panel-icon accent"></span>
                                        <span class="panel-text">
                                            <strong>{locale === "zh-cn" ? "设备同步" : "Device sync"}</strong>
                                            <em>{locale === "zh-cn" ? "安心备份" : "Peaceful backups"}</em>
                                        </span>
                                    </div>
                                </div>
                            </div>
                            <div class="showcase-panel panel-right">
                                <div class="phone-card">
                                    <div class="phone-screen">
                                        <div class="phone-nav"></div>
                                        <div class="phone-stat">
                                            <span class="stat-chip"></span>
                                            <span class="stat-chip short"></span>
                                        </div>
                                        <div class="phone-list">
                                            <div class="phone-item"></div>
                                            <div class="phone-item short"></div>
                                            <div class="phone-item tiny"></div>
                                        </div>
                                    </div>
                                </div>
                                <div class="floating-badge badge-one">{locale === "zh-cn" ? "隐私" : "Privacy"}</div>
                                <div class="floating-badge badge-two">{locale === "zh-cn" ? "同步" : "Sync"}</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="section journey" id="journey">
        <div class="journey-inner">
            <div class="journey-copy section-copy">
                <p class="eyebrow">{copy.journeyKicker}</p>
                <h2>{copy.journeyTitle}</h2>
                <p>{copy.journeyBody}</p>
                <a class="text-link" href={localePath(locale, "journey")}>{copy.journeyLink}<span>→</span></a>
            </div>
            <div class="milestones" aria-hidden="true"><span>01</span><span>Android</span><span>Windows</span><span>Now</span></div>
        </div>
    </section>

    <section class="section support-section" id="support">
        <div class="support-inner section-copy">
            <p class="eyebrow">{copy.supportKicker}</p>
            <h2>{copy.supportTitle}</h2>
            <a class="support-button" href={localePath(locale, "support")}>{copy.supportButton}<span>→</span></a>
        </div>
    </section>
</div>

<style>
    .home {
        position: relative;
    }

    .section {
        padding: clamp(3.6rem, 7vw, 6rem) 0;
    }
    .section > * {
        width: min(1180px, calc(100% - 6rem));
        margin: 0 auto;
    }
    .hero {
        padding-top: clamp(4.4rem, 8vw, 7rem);
        padding-bottom: clamp(3.2rem, 6vw, 4.8rem);
    }

    .hero-inner {
        display: grid;
        grid-template-columns: minmax(280px, 560px) minmax(320px, 1fr);
        gap: 3vw;
        align-items: center;
    }
    .hero-copy {
        padding: 0 0.5rem;
    }
    .eyebrow {
        margin: 0 0 1rem;
        color: #287795;
        font-size: 0.72rem;
        font-weight: 820;
        letter-spacing: 0.16em;
        text-transform: uppercase;
    }
    h1,
    h2 {
        font-family: Georgia, "Times New Roman", serif;
        font-weight: 500;
        letter-spacing: -0.052em;
    }
    h1 {
        margin: 0;
        font-size: clamp(3rem, 5.5vw, 5.2rem);
        line-height: 1.01;
    }
    h2 {
        margin: 0;
        font-size: clamp(2.2rem, 4.5vw, 4.2rem);
        line-height: 1.06;
    }
    .intro {
        max-width: 520px;
        margin: 1.2rem 0 0;
        color: #4f6974;
        font:
            1rem/1.8 Georgia,
            serif;
    }
    .actions {
        display: flex;
        flex-wrap: wrap;
        gap: 1.3rem;
        align-items: center;
        margin-top: 1.8rem;
        position: relative;
        z-index: 1;
    }
    .primary,
    .secondary,
    .tertiary,
    .support-button,
    .text-link {
        cursor: pointer;
    }
    .primary,
    .secondary,
    .tertiary,
    .support-button {
        display: inline-flex;
        gap: 0.6rem;
        align-items: center;
        padding: 0.85rem 1.2rem;
        border-radius: 999px;
        background: #173f50;
        color: #fff;
        font-size: 0.85rem;
        font-weight: 750;
        box-shadow: 0 13px 30px rgba(23, 63, 80, 0.17);
        transition:
            transform 0.18s ease,
            box-shadow 0.18s ease,
            background 0.18s ease;
        pointer-events: auto;
        position: relative;
        z-index: 1;
    }
    .primary:hover,
    .secondary:hover,
    .tertiary:hover,
    .support-button:hover {
        transform: translateY(-3px);
        background: #20596f;
        box-shadow: 0 18px 36px rgba(23, 63, 80, 0.24);
    }
    .primary:active,
    .secondary:active,
    .tertiary:active,
    .support-button:active {
        transform: translateY(0);
        box-shadow: 0 8px 18px rgba(23, 63, 80, 0.12);
        transition:
            transform 0.08s ease,
            box-shadow 0.12s ease;
    }
    .primary:focus,
    .secondary:focus,
    .tertiary:focus,
    .support-button:focus,
    .text-link:focus {
        outline: 3px solid rgba(25, 128, 164, 0.16);
        outline-offset: 3px;
        border-radius: 999px;
    }
    .text-link span,
    .primary span,
    .secondary span,
    .support-button span {
        display: inline-block;
        transition: transform 0.18s ease;
    }
    .primary:hover span,
    .secondary:hover span,
    .support-button:hover span,
    .text-link:hover span {
        transform: translateX(2px);
    }
    .primary.muted {
        background: #315f72;
    }
    .secondary {
        background: rgba(255, 255, 255, 0.92);
        border: 1px solid rgba(23, 63, 80, 0.16);
        color: #173f50;
        box-shadow: 0 10px 24px rgba(11, 42, 56, 0.08);
    }
    .secondary:hover {
        background: rgba(255, 255, 255, 1);
    }
    .tertiary {
        background: transparent;
        border: 1px solid rgba(23, 63, 80, 0.16);
        color: #173f50;
        box-shadow: none;
    }
    .tertiary:hover {
        background: rgba(23, 63, 80, 0.05);
        box-shadow: none;
    }
    .text-link {
        display: inline-flex;
        gap: 0.6rem;
        align-items: center;
        padding-bottom: 0.2rem;
        border-bottom: 1px solid rgba(46, 110, 134, 0.45);
        color: #245e75;
        font-size: 0.83rem;
        font-weight: 760;
        transition:
            gap 0.25s ease,
            color 0.25s ease;
    }
    .text-link:hover {
        gap: 0.9rem;
        color: #1980a4;
    }
    .text-link:active {
        transform: translateY(0);
        color: #156f8f;
    }
    .hero-copy h1,
    .split-copy h2,
    .support-inner h2 {
        white-space: pre-line;
    }
    .actions {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        align-items: center;
        margin-top: 1.8rem;
        position: relative;
        z-index: 1;
    }
    .device-wrap {
        justify-self: end;
        transform: scale(0.92);
        transform-origin: right center;
    }
    .device-wrap :global(.device-stage) {
        width: 520px;
        height: 400px;
    }

    .split-inner {
        display: grid;
        grid-template-columns: 1.05fr 0.9fr;
        gap: 5vw;
        align-items: center;
    }
    .slide-quote {
        margin: 2rem 0 0;
        padding: 0 0 0 1.2rem;
        border-left: 2px solid rgba(43, 124, 154, 0.4);
        color: #254c5d;
        font:
            italic 0.95rem/1.6 Georgia,
            serif;
        max-width: 400px;
    }

    .showcase-wrap {
        width: 100%;
        max-width: 430px;
        margin: 0 auto;
    }
    .showcase-shell {
        position: relative;
        overflow: hidden;
        border-radius: 2rem;
        padding: 0.8rem;
        background: linear-gradient(135deg, rgba(248, 251, 255, 0.98), rgba(239, 247, 248, 0.95));
        box-shadow:
            0 22px 80px rgba(42, 83, 99, 0.16),
            inset 0 1px 0 rgba(255, 255, 255, 0.8);
    }
    .showcase-glow {
        position: absolute;
        inset: 0;
        background:
            radial-gradient(circle at top left, rgba(63, 155, 181, 0.16), transparent 42%),
            radial-gradient(circle at 85% 0%, rgba(131, 106, 181, 0.18), transparent 34%);
        pointer-events: none;
    }
    .showcase-card {
        position: relative;
        overflow: hidden;
        border-radius: 1.4rem;
        border: 1px solid rgba(81, 125, 142, 0.16);
        background: rgba(255, 255, 255, 0.78);
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.82);
        backdrop-filter: blur(18px);
        padding: 1rem;
    }
    .showcase-topbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        padding: 0.2rem 0.2rem 0.85rem;
    }
    .topbar-dots {
        display: flex;
        gap: 0.35rem;
    }
    .topbar-dots span {
        width: 0.58rem;
        height: 0.58rem;
        border-radius: 50%;
        background: linear-gradient(135deg, #8fc8d9, #4b8fa3);
        box-shadow: 0 0 0 2px rgba(255, 255, 255, 0.35);
    }
    .topbar-label {
        color: #4e6973;
        font-size: 0.7rem;
        font-weight: 760;
        letter-spacing: 0.12em;
        text-transform: uppercase;
    }
    .showcase-grid {
        display: grid;
        grid-template-columns: 1.02fr 0.98fr;
        gap: 0.9rem;
    }
    .showcase-panel {
        position: relative;
        border-radius: 1.15rem;
        padding: 1rem;
        min-height: 240px;
    }
    .panel-left {
        background: linear-gradient(145deg, rgba(14, 73, 95, 0.96), rgba(31, 115, 140, 0.92));
        color: #f4fbff;
    }
    .panel-right {
        background: linear-gradient(145deg, rgba(255, 255, 255, 0.9), rgba(239, 247, 250, 0.95));
        border: 1px solid rgba(82, 126, 141, 0.12);
    }
    .feature-pill {
        display: inline-flex;
        align-items: center;
        padding: 0.42rem 0.64rem;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.18);
        color: #f7fdff;
        font-size: 0.7rem;
        font-weight: 760;
        letter-spacing: 0.14em;
        text-transform: uppercase;
    }
    .panel-stack {
        display: grid;
        gap: 0.6rem;
        margin-top: 0.95rem;
    }
    .panel-row {
        display: flex;
        align-items: center;
        gap: 0.65rem;
        padding: 0.7rem 0.75rem;
        border-radius: 0.9rem;
        background: rgba(255, 255, 255, 0.1);
        border: 1px solid rgba(255, 255, 255, 0.13);
    }
    .panel-row.active {
        background: rgba(255, 255, 255, 0.16);
        box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.16);
    }
    .panel-icon {
        width: 0.85rem;
        height: 0.85rem;
        border-radius: 50%;
        background: linear-gradient(135deg, #7dd2e6, #2d7c95);
        box-shadow: 0 0 0 4px rgba(255, 255, 255, 0.16);
    }
    .panel-icon.muted {
        background: linear-gradient(135deg, #b9d4de, #7a95a1);
    }
    .panel-icon.accent {
        background: linear-gradient(135deg, #c4adff, #7a5db5);
    }
    .panel-text {
        display: flex;
        flex-direction: column;
        gap: 0.08rem;
    }
    .panel-text strong {
        font-size: 0.8rem;
        font-weight: 760;
    }
    .panel-text em {
        color: rgba(247, 253, 255, 0.74);
        font-size: 0.68rem;
        font-style: normal;
        letter-spacing: 0.05em;
        text-transform: uppercase;
    }
    .phone-card {
        position: relative;
        width: min(220px, 100%);
        margin: 1rem auto 0;
        padding: 0.8rem;
        border-radius: 1.45rem;
        background: linear-gradient(135deg, #153f50 0%, #2f6c82 55%, #4f9bb0 100%);
        box-shadow: 0 18px 38px rgba(24, 61, 74, 0.22);
    }
    .phone-screen {
        border-radius: 1.1rem;
        padding: 0.85rem;
        background: linear-gradient(145deg, rgba(255, 255, 255, 0.94), rgba(223, 240, 245, 0.9));
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.7);
    }
    .phone-nav {
        width: 42%;
        height: 0.4rem;
        border-radius: 999px;
        background: rgba(62, 95, 107, 0.2);
        margin-bottom: 0.8rem;
    }
    .phone-stat {
        display: flex;
        gap: 0.45rem;
        margin-bottom: 0.7rem;
    }
    .stat-chip {
        width: 70px;
        height: 0.6rem;
        border-radius: 999px;
        background: linear-gradient(90deg, #3f8197, #62b6d1);
    }
    .stat-chip.short {
        width: 44px;
    }
    .phone-list {
        display: grid;
        gap: 0.45rem;
    }
    .phone-item {
        height: 0.72rem;
        border-radius: 999px;
        background: linear-gradient(90deg, rgba(44, 91, 112, 0.34), rgba(44, 91, 112, 0.12));
    }
    .phone-item.short {
        width: 72%;
    }
    .phone-item.tiny {
        width: 48%;
    }
    .floating-badge {
        position: absolute;
        padding: 0.4rem 0.56rem;
        border-radius: 999px;
        border: 1px solid rgba(70, 111, 128, 0.16);
        background: rgba(255, 255, 255, 0.9);
        color: #2f5564;
        font-size: 0.68rem;
        font-weight: 760;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        box-shadow: 0 10px 24px rgba(37, 82, 95, 0.12);
    }
    .badge-one {
        top: 0.5rem;
        right: 0.55rem;
    }
    .badge-two {
        bottom: 0.6rem;
        left: 0.45rem;
    }

    @media (max-width: 760px) {
        .showcase-wrap {
            max-width: 100%;
        }
        .hero-inner {
            grid-template-columns: 1fr;
