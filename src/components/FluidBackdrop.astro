<div class="fluid-field" data-fluid-field aria-hidden="true">
  <i></i><i></i><i></i><i></i>
  <span class="pointer-aura"></span>
</div>

<style>
  .fluid-field { position: fixed; inset: -8rem; z-index: -2; overflow: hidden; pointer-events: none; opacity: .68; contain: strict; isolation: isolate; transform: translateZ(0); backface-visibility: hidden; }
  .fluid-field i { position: absolute; left: 0; top: 0; display: block; filter: blur(54px); will-change: transform; transform: translate3d(0,0,0); backface-visibility: hidden; }
  .fluid-field i:nth-child(1) { width: min(42vw, 620px); height: min(38vw, 520px); border-radius: 43% 57% 61% 39% / 52% 44% 56% 48%; background: rgba(72,190,224,.39); transform: translate3d(6vw,17vh,0); }
  .fluid-field i:nth-child(2) { width: min(48vw, 700px); height: min(38vw, 560px); border-radius: 58% 42% 39% 61% / 44% 57% 43% 56%; background: rgba(124,129,219,.21); transform: translate3d(76vw,5vh,0); }
  .fluid-field i:nth-child(3) { width: min(38vw, 560px); height: min(34vw, 480px); border-radius: 39% 61% 55% 45% / 59% 41% 57% 43%; background: rgba(74,207,158,.23); transform: translate3d(16vw,33vh,0); }
  .fluid-field i:nth-child(4) { width: min(34vw, 500px); height: min(30vw, 430px); border-radius: 62% 38% 47% 53% / 41% 54% 46% 59%; background: rgba(238,177,104,.14); transform: translate3d(48vw,54vh,0); }
  .pointer-aura { position: absolute; width: 19rem; height: 19rem; margin: -9.5rem 0 0 -9.5rem; border-radius: 50%; background: radial-gradient(circle, rgba(232,253,255,.55), rgba(87,181,214,.13) 43%, transparent 70%); filter: blur(15px); opacity: 0; transition: opacity .3s ease; }
  :global(.fluid-active) .pointer-aura { opacity: 1; }
  @media (max-width: 760px) { .fluid-field { opacity: .52; inset: -6rem; } .fluid-field i { min-width: 18rem; min-height: 16rem; } }
  @media (prefers-reduced-motion: reduce) { .fluid-field { opacity: .38; } .pointer-aura { display: none; } }
</style>

<script>
  function startFluidField() {
    const field = document.querySelector<HTMLElement>('[data-fluid-field]');
    const root = field?.closest<HTMLElement>('[data-fluid-root]');
    if (!field || !root || field.dataset.ready) return;
    field.dataset.ready = 'true';
    const blobs = [...field.querySelectorAll<HTMLElement>('i')];
    const aura = field.querySelector<HTMLElement>('.pointer-aura');
    const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
    const pointer = { x: .5, y: .42, tx: .5, ty: .42, on: false, hover: 0, energy: 0 };
    const initial = [[.06,.17], [.76,.05], [.16,.33], [.48,.54]];
    const now = performance.now();
    const drift = initial.map(([x, y], index) => ({
      x, y, targetX: x, targetY: y,
      scale: 1, targetScale: 1,
      rotation: index % 2 ? 12 : -10,
      targetRotation: index % 2 ? 12 : -10,
      nextTargetAt: now,
    }));
    const chooseTarget = (state: (typeof drift)[number], time: number) => {
      state.targetX = -.08 + Math.random() * .92;
      state.targetY = -.06 + Math.random() * .78;
      state.targetScale = .88 + Math.random() * .27;
      state.targetRotation = -34 + Math.random() * 68;
      state.nextTargetAt = time + 3400 + Math.random() * 5200;
    };
    drift.forEach((state, index) => chooseTarget(state, now + index * 430));
    let lastPaint = 0;
    const enter = () => { pointer.on = true; root.classList.add('fluid-active'); };
    const leave = () => { pointer.on = false; root.classList.remove('fluid-active'); };
    const move = (event: PointerEvent) => {
      const x = event.clientX / window.innerWidth;
      const y = event.clientY / window.innerHeight;
      pointer.energy = Math.min(1, pointer.energy + Math.hypot(x - pointer.tx, y - pointer.ty) * 4);
      pointer.tx = x; pointer.ty = y;
    };
    root.addEventListener('pointerenter', enter);
    root.addEventListener('pointerleave', leave);
    root.addEventListener('pointermove', move, { passive: true });
    if (!reduce) {
      let previousTime = performance.now();
      const tick = (now: number) => {
        requestAnimationFrame(tick);
        if (now - lastPaint < 22) return;
        const delta = Math.min(48, Math.max(0, now - previousTime));
        previousTime = now;
        lastPaint = now;
        const pointerEase = 1 - Math.exp(-delta / 180);
        const hoverEase = 1 - Math.exp(-delta / 320);
        pointer.x += (pointer.tx - pointer.x) * pointerEase;
        pointer.y += (pointer.ty - pointer.y) * pointerEase;
        pointer.hover += ((pointer.on ? 1 : 0) - pointer.hover) * hoverEase;
        pointer.energy *= Math.pow(.94, delta / 22);
        const width = window.innerWidth;
        const height = window.innerHeight;
        if (aura) {
          const fieldBounds = field.getBoundingClientRect();
          aura.style.transform = `translate3d(${pointer.x * width - fieldBounds.left}px,${pointer.y * height - fieldBounds.top}px,0) scale(${1 + pointer.energy * .18})`;
        }
        blobs.forEach((blob, index) => {
          const state = drift[index];
          if (now >= state.nextTargetAt) chooseTarget(state, now);
          const positionEase = 1 - Math.exp(-delta / 3100);
          const shapeEase = 1 - Math.exp(-delta / 2400);
          state.x += (state.targetX - state.x) * positionEase;
          state.y += (state.targetY - state.y) * positionEase;
          state.scale += (state.targetScale - state.scale) * shapeEase;
          state.rotation += (state.targetRotation - state.rotation) * shapeEase;
          let x = state.x * width;
          let y = state.y * height;
          const dx = pointer.x * width - x;
          const dy = pointer.y * height - y;
          const distance = Math.max(100, Math.hypot(dx, dy));
          const influence = pointer.hover * Math.max(0, 1 - distance / (width * .58));
          x += dx * influence * (.1 + index * .012);
          y += dy * influence * (.1 + index * .01);
          const scale = state.scale + influence * .14 + pointer.energy * .025;
          const rotation = state.rotation + influence * 10;
          blob.style.transform = `translate3d(${x}px,${y}px,0) rotate(${rotation}deg) scale(${scale})`;
        });
      };
      tick(previousTime);
    }
    // The ambient layer persists across Astro page transitions, so its animation
    // intentionally keeps the same frame loop and random drift state.
  }
  document.addEventListener('astro:page-load', startFluidField);
  startFluidField();
</script>
