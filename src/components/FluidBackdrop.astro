<div class="fluid-field" data-fluid-field aria-hidden="true">
  <i></i><i></i><i></i><i></i>
</div>

<style>
  .fluid-field { position: fixed; inset: -8rem; z-index: -2; overflow: hidden; pointer-events: none; opacity: .72; contain: strict; isolation: isolate; transform: translateZ(0); backface-visibility: hidden; }
  .fluid-field i { position: absolute; left: 0; top: 0; display: block; filter: blur(54px); mix-blend-mode: screen; will-change: transform; transform: translate3d(0,0,0); backface-visibility: hidden; }
  .fluid-field i:nth-child(1) { width: min(44vw, 640px); height: min(40vw, 540px); border-radius: 43% 57% 61% 39% / 52% 44% 56% 48%; transform: translate3d(6vw,17vh,0); }
  .fluid-field i:nth-child(2) { width: min(50vw, 720px); height: min(40vw, 580px); border-radius: 58% 42% 39% 61% / 44% 57% 43% 56%; transform: translate3d(76vw,5vh,0); }
  .fluid-field i:nth-child(3) { width: min(40vw, 580px); height: min(36vw, 500px); border-radius: 39% 61% 55% 45% / 59% 41% 57% 43%; transform: translate3d(16vw,33vh,0); }
  .fluid-field i:nth-child(4) { width: min(36vw, 520px); height: min(32vw, 450px); border-radius: 62% 38% 47% 53% / 41% 54% 46% 59%; transform: translate3d(48vw,54vh,0); }
  @media (max-width: 760px) { .fluid-field { opacity: .56; inset: -6rem; } .fluid-field i { min-width: 18rem; min-height: 16rem; } }
  @media (prefers-reduced-motion: reduce) { .fluid-field { opacity: .38; } }
</style>

<script>
  function startFluidField() {
    const field = document.querySelector('[data-fluid-field]') as HTMLElement | null;
    if (!field || field.dataset.ready) return;
    field.dataset.ready = 'true';
    const blobs = [...field.querySelectorAll('i')] as HTMLElement[];
    const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
    const initial: [number, number][] = [[.06,.17], [.76,.05], [.16,.33], [.48,.54]];
    const now = performance.now();
    const drift = initial.map(([x, y], index) => ({
      x, y, targetX: x, targetY: y,
      scale: 1, targetScale: 1,
      rotation: index % 2 ? 12 : -10,
      targetRotation: index % 2 ? 12 : -10,
      nextTargetAt: now,
    }));
    const chooseTarget = (state: typeof drift[number], time: number) => {
      state.targetX = -.08 + Math.random() * .92;
      state.targetY = -.06 + Math.random() * .78;
      state.targetScale = .88 + Math.random() * .27;
      state.targetRotation = -34 + Math.random() * 68;
      state.nextTargetAt = time + 3400 + Math.random() * 5200;
    };
    drift.forEach((state, index) => chooseTarget(state, now + index * 430));
    const blobPalette = [
      { phase: 0, speed: .032, sat: 84, light: 58, alpha: .62 },
      { phase: 2.1, speed: -.028, sat: 88, light: 55, alpha: .56 },
      { phase: 4.0, speed: .036, sat: 86, light: 56, alpha: .52 },
      { phase: 5.8, speed: -.024, sat: 82, light: 54, alpha: .48 },
    ];
    let lastPaint = 0;
    let colorTime = 0;
    if (!reduce) {
      let previousTime = performance.now();
      const tick = (now: number) => {
        requestAnimationFrame(tick);
        if (now - lastPaint < 22) return;
        const delta = Math.min(48, Math.max(0, now - previousTime));
        previousTime = now;
        lastPaint = now;
        colorTime += delta * .016;
        const width = window.innerWidth;
        const height = window.innerHeight;
        blobs.forEach((blob, index) => {
          const state = drift[index];
          const pal = blobPalette[index];
          if (now >= state.nextTargetAt) chooseTarget(state, now);
          const positionEase = 1 - Math.exp(-delta / 3100);
          const shapeEase = 1 - Math.exp(-delta / 2400);
          state.x += (state.targetX - state.x) * positionEase;
          state.y += (state.targetY - state.y) * positionEase;
          state.scale += (state.targetScale - state.scale) * shapeEase;
          state.rotation += (state.targetRotation - state.rotation) * shapeEase;
          const hue = ((pal.phase + colorTime * pal.speed) * 180 / Math.PI + 360) % 360;
          blob.style.background = `hsla(${hue}, ${pal.sat}%, ${pal.light}%, ${pal.alpha})`;
          blob.style.transform = `translate3d(${state.x * width}px,${state.y * height}px,0) rotate(${state.rotation}deg) scale(${state.scale})`;
        });
      };
      tick(previousTime);
    }
  }
  document.addEventListener('astro:page-load', startFluidField);
  startFluidField();
</script>
