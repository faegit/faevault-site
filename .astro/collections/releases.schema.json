{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "locale": {
      "type": "string",
      "enum": [
        "zh-cn",
        "en"
      ]
    },
    "translationKey": {
      "type": "string",
      "minLength": 1
    },
    "order": {
      "default": 0,
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "draft": {
      "default": false,
      "type": "boolean"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "publishedAt": {
      "type": "string",
      "format": "date-time"
    },
    "githubReleaseUrl": {
      "type": "string",
      "format": "uri"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "description",
    "locale",
    "translationKey",
    "version",
    "publishedAt",
    "githubReleaseUrl"
  ]
}